{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis",
  "version": "0.1.3",
  "identifier": "com.agentguard-desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "beforeBuildCommand": "npm run build:bundle",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Aegis",
        "width": 1170,
        "height": 810,
        "minWidth": 1170,
        "minHeight": 810,
        "resizable": true,
        "acceptFirstMouse": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/agentguard"
    ],
    "macOS": {
      "entitlements": "entitlements.mac.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13"
    },
    "targets": [
      "app",
      "dmg"
    ]
  }
}
